---
<footer class="site-footer">
  <div class="footer-container">
    <div class="footer-main">
      <div class="footer-brand">
        <a href="/" class="logo">
          <span class="logo-accent">P</span>RIME<span class="logo-dot">.</span>
        </a>
        <p>Serveur FiveM GTA V — Roleplay sérieux<br />Communauté active & passionnée.</p>
        <div class="footer-ip">
          <span class="ip-label">IP Serveur</span>
          <code>51.222.255.96:30122</code>
        </div>
      </div>
      <div class="footer-cols">
        <div class="footer-col">
          <span class="col-title">Navigation</span>
          <a href="#features">Fonctionnalités</a>
          <a href="#join">Comment rejoindre</a>
          <a href="#staff">Équipe</a>
          <a href="#community">Communauté</a>
        </div>
        <div class="footer-col">
          <span class="col-title">Serveur</span>
          <a href="fivem://connect/51.222.255.96:30122" class="btn-primary connect-btn">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
            Se connecter
          </a>
          <a href="#community" class="btn-ghost connect-btn">Discord →</a>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <span>&copy; {new Date().getFullYear()} Prime Roleplay. Tous droits réservés.</span>
      <span>Fondé par <strong>Xeast7487</strong></span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--bg-2);
    border-top: 1px solid var(--border);
    padding: 4rem 2rem 2rem;
  }

  .footer-container {
    max-width: 1140px;
    margin: 0 auto;
  }

  .footer-main {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 4rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid var(--border);
    align-items: start;
  }

  .logo {
    font-family: var(--font-display);
    font-size: 1.55rem;
    letter-spacing: 0.12em;
    color: var(--white);
    display: inline-block;
    margin-bottom: 0.9rem;
  }
  .logo-accent { color: var(--accent); }
  .logo-dot { color: var(--accent); }

  .footer-brand p {
    font-size: 0.85rem;
    color: var(--gray);
    line-height: 1.75;
    margin-bottom: 1.25rem;
  }

  .footer-ip {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .ip-label {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .footer-ip code {
    font-family: 'Courier New', monospace;
    font-size: 0.82rem;
    color: var(--accent);
    background: var(--accent-glow);
    border: 1px solid var(--accent-border);
    padding: 0.3rem 0.7rem;
    border-radius: var(--radius);
    width: fit-content;
  }

  .footer-cols {
    display: flex;
    gap: 3.5rem;
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    min-width: 130px;
  }

  .col-title {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.15rem;
  }

  .footer-col a {
    font-size: 0.85rem;
    color: var(--gray);
    transition: color 0.2s;
  }
  .footer-col a:hover { color: var(--white); }

  .connect-btn {
    padding: 0.55rem 1rem !important;
    font-size: 0.74rem !important;
    width: fit-content;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 1.75rem;
    font-size: 0.78rem;
    color: var(--muted);
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .footer-bottom strong {
    color: var(--accent);
    font-weight: 600;
  }

  @media (max-width: 768px) {
    .footer-main { grid-template-columns: 1fr; gap: 2.5rem; }
    .footer-cols { flex-direction: column; gap: 2rem; }
    .footer-bottom { justify-content: center; text-align: center; }
  }
</style>
