---
---
<div id="announce-banner">
  <div class="announce-inner">
    <span class="announce-pulse"></span>
    <span class="announce-text">
      <strong>OUVERTURE PROCHAINEMENT</strong>
      <span class="announce-sep">—</span>
      Prime Roleplay ouvre très bientôt ses portes. Rejoins le Discord pour ne rien manquer&nbsp;!
    </span>
    <a class="announce-cta" href="https://discord.gg/primeroleplay" target="_blank" rel="noopener">
      Discord →
    </a>
  </div>
</div>

<header id="site-header">
  <div class="nav-inner">
    <a href="/" class="logo">
      <span class="logo-accent">P</span>RIME<span class="logo-dot">.</span>
    </a>
    <nav class="nav-links">
      <a href="#features">Fonctionnalités</a>
      <a href="#join">Rejoindre</a>
      <a href="#staff">Équipe</a>
      <a href="#community">Communauté</a>
    </nav>
    <a class="nav-cta btn-primary" href="fivem://connect/51.222.255.96:30122">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
      Jouer
    </a>
    <button class="burger" id="burger" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<div class="mobile-overlay" id="mobile-overlay">
  <button class="overlay-close" id="overlay-close">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18M6 6l12 12"/></svg>
  </button>
  <nav class="overlay-nav">
    <a href="#features" class="ol-link">Fonctionnalités</a>
    <a href="#join" class="ol-link">Rejoindre</a>
    <a href="#staff" class="ol-link">Équipe</a>
    <a href="#community" class="ol-link">Communauté</a>
    <a href="fivem://connect/51.222.255.96:30122" class="btn-primary" style="margin-top:0.5rem;justify-content:center;">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
      Jouer maintenant
    </a>
  </nav>
</div>

<style>
  /* ── ANNOUNCE BANNER ───────────────── */
  #announce-banner {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 101;
    height: 44px;
    background: linear-gradient(90deg, #1a0f00 0%, #0d0d18 40%, #1a0f00 100%);
    border-bottom: 1px solid rgba(245, 158, 11, 0.35);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  #announce-banner::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent 0%, rgba(245,158,11,0.06) 50%, transparent 100%);
    animation: banner-shimmer 3s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes banner-shimmer {
    0%, 100% { opacity: 0; }
    50% { opacity: 1; }
  }

  .announce-inner {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0 1.5rem;
    position: relative;
    z-index: 1;
  }

  .announce-pulse {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
    flex-shrink: 0;
    box-shadow: 0 0 0 0 rgba(245, 158, 11, 0.6);
    animation: pulse-banner 1.8s ease-in-out infinite;
  }

  @keyframes pulse-banner {
    0%, 100% { box-shadow: 0 0 0 0 rgba(245, 158, 11, 0.6); }
    50% { box-shadow: 0 0 0 7px rgba(245, 158, 11, 0); }
  }

  .announce-text {
    font-size: 0.78rem;
    font-weight: 500;
    color: rgba(244, 243, 238, 0.82);
    letter-spacing: 0.02em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .announce-text strong {
    font-weight: 800;
    color: var(--accent);
    letter-spacing: 0.1em;
    font-size: 0.72rem;
    text-transform: uppercase;
  }

  .announce-sep {
    opacity: 0.35;
    margin: 0 0.1rem;
  }

  .announce-cta {
    flex-shrink: 0;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    background: rgba(245, 158, 11, 0.1);
    border: 1px solid rgba(245, 158, 11, 0.3);
    border-radius: 4px;
    padding: 0.22rem 0.7rem;
    transition: background 0.2s, border-color 0.2s;
    white-space: nowrap;
  }
  .announce-cta:hover {
    background: rgba(245, 158, 11, 0.2);
    border-color: var(--accent);
  }

  @media (max-width: 600px) {
    .announce-sep, .announce-text > :not(strong) { display: none; }
    .announce-text strong { font-size: 0.7rem; }
  }

  /* ── NAV ───────────────────────────── */
  #site-header {
    position: fixed;
    top: 44px; left: 0; right: 0;
    z-index: 100;
    background: rgba(8, 8, 15, 0.88);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border);
  }

  .nav-inner {
    max-width: 1140px;
    margin: 0 auto;
    padding: 0 2rem;
    height: 66px;
    display: flex;
    align-items: center;
    gap: 2.5rem;
  }

  .logo {
    font-family: var(--font-display);
    font-size: 1.55rem;
    letter-spacing: 0.12em;
    color: var(--white);
    flex-shrink: 0;
  }
  .logo-accent { color: var(--accent); }
  .logo-dot { color: var(--accent); }

  .nav-links {
    display: flex;
    gap: 2rem;
    margin-left: auto;
  }

  .nav-links a {
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--gray);
    letter-spacing: 0.04em;
    position: relative;
    transition: color 0.2s;
  }
  .nav-links a::after {
    content: '';
    position: absolute;
    bottom: -3px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--accent);
    transition: width 0.25s ease;
  }
  .nav-links a:hover { color: var(--white); }
  .nav-links a:hover::after { width: 100%; }

  .nav-cta { padding: 0.6rem 1.2rem; font-size: 0.75rem; }

  .burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    margin-left: auto;
  }
  .burger span {
    display: block;
    width: 20px;
    height: 2px;
    background: var(--white);
    border-radius: 2px;
    transition: transform 0.25s, opacity 0.25s;
  }

  /* Full-screen overlay menu */
  .mobile-overlay {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 200;
    background: var(--bg-2);
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }
  .mobile-overlay.open { display: flex; }

  .overlay-close {
    position: absolute;
    top: 1.25rem;
    right: 1.5rem;
    background: none;
    border: none;
    color: var(--gray);
    cursor: pointer;
    padding: 0.5rem;
    transition: color 0.2s;
  }
  .overlay-close:hover { color: var(--white); }

  .overlay-nav {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    text-align: center;
    width: 100%;
    max-width: 280px;
  }

  .ol-link {
    font-family: var(--font-display);
    font-size: 2.2rem;
    letter-spacing: 0.1em;
    color: var(--gray);
    transition: color 0.2s;
  }
  .ol-link:hover { color: var(--accent); }

  @media (max-width: 768px) {
    .nav-links, .nav-cta { display: none; }
    .burger { display: flex; }
  }
</style>

<script>
  const burger = document.getElementById('burger');
  const overlay = document.getElementById('mobile-overlay');
  const closeBtn = document.getElementById('overlay-close');

  burger?.addEventListener('click', () => overlay?.classList.add('open'));
  closeBtn?.addEventListener('click', () => overlay?.classList.remove('open'));
  overlay?.querySelectorAll('.ol-link, .btn-primary').forEach(l =>
    l.addEventListener('click', () => overlay?.classList.remove('open'))
  );
</script>
