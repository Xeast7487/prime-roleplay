---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<Layout title="Prime Roleplay — Serveur FiveM GTA V">
  <Nav />
  <main>

    <!-- ── HERO ────────────────────────────── -->
    <section class="hero">
      <div class="hero-wordmark" aria-hidden="true">PRIME</div>
      <div class="container">
        <div class="hero-content">

          <div class="hero-badge reveal">
            <span class="badge-dot"></span>
            <span>Serveur en ligne</span>
            <span class="badge-sep">·</span>
            <span class="badge-ip">51.222.255.96:30122</span>
          </div>

          <h1 class="hero-title">
            <span class="hero-t1 reveal delay-1">PRIME</span>
            <span class="hero-t2 reveal delay-2">ROLEPLAY.</span>
          </h1>

          <p class="hero-desc reveal delay-3">
            Le serveur FiveM GTA V où chaque histoire compte.<br />
            Économie réaliste, factions profondes, communauté soudée.
          </p>

          <div class="hero-actions reveal delay-4">
            <a class="btn-primary" href="fivem://connect/51.222.255.96:30122">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
              Jouer maintenant
            </a>
            <a class="btn-ghost" href="#join">Comment rejoindre →</a>
          </div>

          <div class="hero-tags reveal delay-5">
            <span>FiveM</span>
            <span>GTA V</span>
            <span>Roleplay Sérieux</span>
            <span>Communauté FR</span>
          </div>

        </div>
      </div>
      <div class="hero-scroll" aria-hidden="true">
        <div class="scroll-bar"></div>
        <span>Défiler</span>
      </div>
    </section>

    <!-- ── STATS BAND ───────────────────────── -->
    <div class="stats-band">
      <div class="container">
        <div class="stats-row">
          <div class="stat-cell reveal">
            <span class="stat-num"><span data-target="500">0</span>+</span>
            <span class="stat-lbl">Membres inscrits</span>
          </div>
          <div class="stat-cell reveal delay-1">
            <span class="stat-num"><span data-target="12">0</span></span>
            <span class="stat-lbl">Factions actives</span>
          </div>
          <div class="stat-cell reveal delay-2">
            <span class="stat-num"><span data-target="200">0</span>+</span>
            <span class="stat-lbl">Véhicules custom</span>
          </div>
          <div class="stat-cell reveal delay-3">
            <span class="stat-num"><span data-target="3">0</span></span>
            <span class="stat-lbl">Ans d'expérience</span>
          </div>
        </div>
      </div>
    </div>

    <!-- ── FEATURES ─────────────────────────── -->
    <section class="features-section" id="features">
      <div class="container">
        <div class="section-header reveal">
          <span class="eyebrow">Expérience de jeu</span>
          <h2 class="section-title">Un univers <span>complet</span></h2>
          <p class="section-sub">Chaque aspect du roleplay a été pensé pour offrir l'immersion maximale.</p>
        </div>
        <div class="features-grid">

          <div class="feat-card reveal">
            <div class="feat-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/><line x1="12" y1="12" x2="12" y2="16"/><line x1="10" y1="14" x2="14" y2="14"/></svg>
            </div>
            <h3>Économie Réaliste</h3>
            <p>Emplois légaux et illégaux, banques, marchés noirs, propriétés immobilières et bien plus.</p>
          </div>

          <div class="feat-card reveal delay-1">
            <div class="feat-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M19 17H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h11l5 5v6a2 2 0 0 1-2 2z"/><circle cx="17" cy="17" r="2"/><circle cx="7" cy="17" r="2"/></svg>
            </div>
            <h3>Véhicules Custom</h3>
            <p>Des centaines de voitures, motos et véhicules personnalisables avec un garage dédié.</p>
          </div>

          <div class="feat-card reveal delay-2">
            <div class="feat-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            </div>
            <h3>Immobilier</h3>
            <p>Achète et décore ta maison, gère tes propriétés ou ouvre ton propre commerce.</p>
          </div>

          <div class="feat-card reveal delay-3">
            <div class="feat-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <h3>Forces de l'Ordre</h3>
            <p>BCSO, LSPD et SASP avec des procédures réalistes et une hiérarchie structurée.</p>
          </div>

          <div class="feat-card reveal delay-4">
            <div class="feat-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
            </div>
            <h3>Système Médical</h3>
            <p>EMS complet, blessures persistantes, hôpitaux et ambulances RP.</p>
          </div>

          <div class="feat-card reveal delay-5">
            <div class="feat-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 1v22M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
            </div>
            <h3>Justice & Judiciaire</h3>
            <p>Avocats, tribunaux, procès et système carcéral pour un RP judiciaire immersif.</p>
          </div>

        </div>
      </div>
    </section>

    <!-- ── HOW TO JOIN ───────────────────────── -->
    <section class="join-section" id="join">
      <div class="container">
        <div class="section-header reveal" style="text-align:center">
          <span class="eyebrow centered">Démarrer</span>
          <h2 class="section-title">Comment <span>rejoindre</span></h2>
          <p class="section-sub" style="margin-left:auto;margin-right:auto">
            Prêt à écrire ton histoire sur Prime RP ? 3 étapes simples.
          </p>
        </div>

        <div class="steps-row">
          <div class="step-card reveal">
            <div class="step-n">01</div>
            <div class="step-line"></div>
            <h3>Installe FiveM</h3>
            <p>Télécharge le client FiveM gratuit sur fivem.net. Compatible GTA V Steam, Epic Games et Rockstar.</p>
          </div>
          <div class="step-card reveal delay-2">
            <div class="step-n">02</div>
            <div class="step-line"></div>
            <h3>Rejoins le Discord</h3>
            <p>Rejoins notre serveur Discord pour lire les règles, faire ta demande de whitelist et rencontrer la communauté.</p>
          </div>
          <div class="step-card reveal delay-4">
            <div class="step-n">03</div>
            <div class="step-line"></div>
            <h3>Connecte-toi</h3>
            <p>Une fois approuvé, clique sur le bouton ci-dessous ou cherche "Prime Roleplay" dans le navigateur FiveM.</p>
          </div>
        </div>

        <div class="join-cta-row reveal delay-2">
          <a class="btn-primary" href="fivem://connect/51.222.255.96:30122">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
            Se connecter au serveur
          </a>
          <div class="join-ip-box">
            <span class="jip-label">IP du serveur</span>
            <span class="jip-addr">51.222.255.96:30122</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ── STAFF ────────────────────────────── -->
    <section class="staff-section" id="staff">
      <div class="container">
        <div class="section-header reveal">
          <span class="eyebrow">L'équipe</span>
          <h2 class="section-title">Notre <span>staff</span></h2>
          <p class="section-sub">Des passionnés dédiés à maintenir une expérience de jeu de qualité.</p>
        </div>

        <div class="staff-row">

<div class="staff-card reveal delay-1">
            <div class="staff-avatar">
              <div class="av-ring"></div>
              <div class="av-inner teal">C</div>
            </div>
            <div class="staff-role-badge badge-dev">Développeur</div>
            <h3>Calvin Mouse</h3>
            <p>Développeur expérimenté qui contribue à l'amélioration continue du serveur avec des scripts optimisés.</p>
          </div>

          <div class="staff-card staff-join-card reveal delay-2">
            <div class="join-plus">+</div>
            <h3>Rejoins l'équipe</h3>
            <p>Tu veux contribuer à Prime RP ? On recherche des modérateurs, développeurs et responsables RP motivés.</p>
            <a class="btn-ghost" href="#community" style="margin-top:1.25rem;font-size:0.75rem;padding:0.65rem 1.2rem;">Postuler →</a>
          </div>

        </div>
      </div>
    </section>

    <!-- ── COMMUNITY ──────────────────────────── -->
    <section class="community-section" id="community">
      <div class="comm-bg"></div>
      <div class="comm-glow"></div>
      <div class="container">
        <div class="comm-content reveal">
          <span class="eyebrow">Communauté</span>
          <h2 class="comm-title">REJOINS<br/><span>LA FAMILLE.</span></h2>
          <p class="section-sub">
            Plus de 500 membres actifs sur notre Discord. Règles du serveur,
            demandes de whitelist, événements et bien plus t'attendent.
          </p>
          <div class="comm-actions">
            <a class="btn-discord" href="https://discord.gg/primeroleplay" target="_blank" rel="noopener">
              <svg width="18" height="14" viewBox="0 0 71 55" fill="currentColor"><path d="M60.1 4.9A58.5 58.5 0 0 0 45.6.7a.2.2 0 0 0-.2.1c-.6 1.1-1.3 2.6-1.8 3.7a54 54 0 0 0-16.2 0A38.3 38.3 0 0 0 25.6.8a.2.2 0 0 0-.2-.1 58.4 58.4 0 0 0-14.5 4.2.2.2 0 0 0-.1.1C1.6 18.7-.9 32.1.3 45.4c0 .1.1.2.2.2a58.8 58.8 0 0 0 17.7 9 .2.2 0 0 0 .2-.1 42 42 0 0 0 3.6-5.9.2.2 0 0 0-.1-.3 38.7 38.7 0 0 1-5.5-2.6.2.2 0 0 1 0-.4l1.1-.9a.2.2 0 0 1 .2 0c11.5 5.3 24 5.3 35.4 0a.2.2 0 0 1 .2 0l1.1.8a.2.2 0 0 1 0 .4 36.2 36.2 0 0 1-5.5 2.6.2.2 0 0 0-.1.3 47 47 0 0 0 3.6 5.9c.1.1.2.1.3.1a58.6 58.6 0 0 0 17.7-9 .2.2 0 0 0 .1-.2c1.5-15.4-2.5-28.7-10.5-40.5a.2.2 0 0 0-.1-.1zM23.7 37.3c-3.5 0-6.4-3.2-6.4-7.2s2.8-7.2 6.4-7.2c3.6 0 6.5 3.3 6.4 7.2 0 4-2.9 7.2-6.4 7.2zm23.6 0c-3.5 0-6.4-3.2-6.4-7.2s2.8-7.2 6.4-7.2c3.6 0 6.5 3.3 6.4 7.2 0 4-2.8 7.2-6.4 7.2z"/></svg>
              Rejoindre le Discord
            </a>
            <a class="btn-primary" href="fivem://connect/51.222.255.96:30122">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
              Jouer maintenant
            </a>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  main { padding-top: 110px; }

  /* ── HERO ───────────────────────── */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 8rem 0 6rem;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(244, 243, 238, 0.065) 1px, transparent 1px);
    background-size: 32px 32px;
    z-index: 0;
  }

  .hero::after {
    content: '';
    position: absolute;
    bottom: -120px;
    right: -120px;
    width: 750px;
    height: 750px;
    border-radius: 50%;
    background: radial-gradient(ellipse, rgba(245, 158, 11, 0.07) 0%, transparent 65%);
    pointer-events: none;
    z-index: 0;
  }

  .hero-wordmark {
    position: absolute;
    right: -2%;
    top: 50%;
    transform: translateY(-50%);
    font-family: var(--font-display);
    font-size: clamp(14rem, 30vw, 26rem);
    letter-spacing: 0.06em;
    line-height: 1;
    color: transparent;
    -webkit-text-stroke: 1px rgba(245, 158, 11, 0.05);
    pointer-events: none;
    user-select: none;
    z-index: 0;
    white-space: nowrap;
  }

  .hero .container { position: relative; z-index: 1; }

  .hero-content { max-width: 700px; }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: rgba(244, 243, 238, 0.04);
    border: 1px solid var(--border);
    border-radius: 100px;
    padding: 0.38rem 1rem;
    font-size: 0.72rem;
    color: var(--gray);
    margin-bottom: 2rem;
    letter-spacing: 0.03em;
  }

  .badge-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #22c55e;
    box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.5);
    animation: pulse-dot 2s ease infinite;
    flex-shrink: 0;
  }

  @keyframes pulse-dot {
    0%, 100% { box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.5); }
    50% { box-shadow: 0 0 0 6px rgba(34, 197, 94, 0); }
  }

  .badge-sep { opacity: 0.22; }
  .badge-ip { font-family: 'Courier New', monospace; color: var(--accent); }

  .hero-title {
    font-family: var(--font-display);
    line-height: 0.88;
    letter-spacing: 0.03em;
    margin-bottom: 1.75rem;
    display: flex;
    flex-direction: column;
  }

  .hero-t1 {
    font-size: clamp(5.5rem, 16vw, 13.5rem);
    color: var(--white);
  }

  .hero-t2 {
    font-size: clamp(5.5rem, 16vw, 13.5rem);
    color: var(--accent);
  }

  .hero-desc {
    font-size: 1rem;
    color: var(--gray);
    line-height: 1.8;
    max-width: 420px;
    margin-bottom: 2.25rem;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
  }

  .hero-tags {
    display: flex;
    gap: 0.65rem;
    flex-wrap: wrap;
  }

  .hero-tags span {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    padding: 0.26rem 0.7rem;
    border: 1px solid var(--border);
    border-radius: 100px;
  }

  .hero-scroll {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    z-index: 1;
  }

  .scroll-bar {
    width: 1px;
    height: 44px;
    background: linear-gradient(to bottom, var(--accent), transparent);
    animation: scroll-pulse 1.6s ease-in-out infinite;
  }

  @keyframes scroll-pulse {
    0% { transform: scaleY(0); transform-origin: top; opacity: 0; }
    50% { transform: scaleY(1); opacity: 1; }
    100% { transform: scaleY(0); transform-origin: bottom; opacity: 0; }
  }

  .hero-scroll span {
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
  }

  @media (max-width: 900px) { .hero-wordmark { display: none; } }
  @media (max-width: 560px) { .hero-actions { flex-direction: column; align-items: flex-start; } }

  /* ── STATS ─────────────────────── */
  .stats-band {
    background: var(--bg-2);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 2.75rem 0;
  }

  .stats-row {
    display: flex;
    align-items: stretch;
  }

  .stat-cell {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 0.3rem;
    padding: 0.5rem 1.5rem;
    border-right: 1px solid var(--border);
  }

  .stat-cell:last-child { border-right: none; }

  .stat-num {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4rem);
    letter-spacing: 0.04em;
    color: var(--accent);
    line-height: 1;
  }

  .stat-lbl {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
  }

  @media (max-width: 650px) {
    .stats-row { flex-wrap: wrap; }
    .stat-cell {
      flex: 1 1 50%;
      border-right: none;
      border-bottom: 1px solid var(--border);
      padding: 1.25rem 1rem;
    }
    .stat-cell:nth-last-child(-n+2) { border-bottom: none; }
  }

  /* ── FEATURES ──────────────────── */
  .features-section { padding: 7rem 0; }

  .section-header { margin-bottom: 3.5rem; }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .feat-card {
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.75rem;
    position: relative;
    overflow: hidden;
    transition: border-color 0.25s, transform 0.2s;
  }

  .feat-card::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 3px;
    background: var(--accent);
    border-radius: 0 2px 2px 0;
    transform: scaleY(0);
    transform-origin: bottom;
    transition: transform 0.28s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .feat-card:hover { border-color: var(--accent-border); transform: translateY(-3px); }
  .feat-card:hover::before { transform: scaleY(1); }

  .feat-icon {
    width: 42px;
    height: 42px;
    border-radius: 8px;
    background: var(--accent-glow);
    border: 1px solid var(--accent-border);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent);
    margin-bottom: 1.1rem;
  }

  .feat-card h3 { font-size: 0.95rem; font-weight: 700; margin-bottom: 0.45rem; }
  .feat-card p { font-size: 0.85rem; color: var(--gray); line-height: 1.7; }

  @media (max-width: 880px) { .features-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 540px) { .features-grid { grid-template-columns: 1fr; } }

  /* ── JOIN ──────────────────────── */
  .join-section {
    padding: 7rem 0;
    position: relative;
    overflow: hidden;
  }

  .join-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--bg-2);
    background-image: repeating-linear-gradient(
      -55deg,
      rgba(245, 158, 11, 0.025) 0,
      rgba(245, 158, 11, 0.025) 1px,
      transparent 0,
      transparent 50%
    );
    background-size: 22px 22px;
    z-index: 0;
  }

  .join-section .container { position: relative; z-index: 1; }

  .steps-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-bottom: 3.5rem;
  }

  .step-card {
    background: var(--bg-3);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 2rem 1.75rem;
    transition: border-color 0.2s;
  }

  .step-card:hover { border-color: var(--accent-border); }

  .step-n {
    font-family: var(--font-display);
    font-size: 4.5rem;
    color: var(--accent);
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .step-line {
    width: 26px;
    height: 2px;
    background: var(--accent);
    border-radius: 2px;
    margin-bottom: 1.1rem;
    opacity: 0.55;
  }

  .step-card h3 { font-size: 1rem; font-weight: 700; margin-bottom: 0.5rem; }
  .step-card p { font-size: 0.85rem; color: var(--gray); line-height: 1.7; }

  .join-cta-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2.5rem;
    flex-wrap: wrap;
  }

  .join-ip-box { display: flex; flex-direction: column; gap: 0.3rem; }

  .jip-label {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .jip-addr {
    font-family: 'Courier New', monospace;
    font-size: 0.88rem;
    color: var(--accent);
    background: var(--accent-glow);
    border: 1px solid var(--accent-border);
    padding: 0.36rem 0.85rem;
    border-radius: var(--radius);
  }

  @media (max-width: 800px) { .steps-row { grid-template-columns: 1fr; } }

  /* ── STAFF ─────────────────────── */
  .staff-section { padding: 7rem 0; }

  .staff-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .staff-card {
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    transition: border-color 0.2s, transform 0.2s;
  }

  .staff-card:hover { border-color: var(--accent-border); transform: translateY(-3px); }

  .staff-avatar {
    position: relative;
    width: 68px;
    height: 68px;
    margin-bottom: 1.25rem;
  }

  .av-ring {
