---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const features = [
  { icon: '💼', title: 'Économie Réaliste', desc: 'Emplois légaux et illégaux, banques, marchés noirs, propriétés immobilières et bien plus.' },
  { icon: '🚗', title: 'Véhicules Custom', desc: 'Des centaines de voitures, motos et véhicules personnalisables avec un garage dédié.' },
  { icon: '🏠', title: 'Immobilier', desc: 'Achète et décore ta maison, gère tes propriétés ou ouvre ton commerce.' },
  { icon: '👮', title: 'Forces de l\'Ordre', desc: 'BCSO, LSPD et SASP avec des procédures réalistes et une hiérarchie structurée.' },
  { icon: '🏥', title: 'Système Médical', desc: 'EMS complet, blessures persistantes, hôpitaux et ambulances roleplays.' },
  { icon: '⚖️', title: 'Justice & Judiciaire', desc: 'Avocats, tribunaux, procès et système carcéral pour un RP judiciaire immersif.' },
];

const steps = [
  { n: '01', title: 'Installe FiveM', desc: 'Télécharge le client FiveM gratuit sur fivem.net. Compatible GTA V Steam, Epic Games et Rockstar.' },
  { n: '02', title: 'Rejoins le Discord', desc: 'Rejoins notre serveur Discord pour lire les règles, faire ta demande de whitelist et rencontrer la communauté.' },
  { n: '03', title: 'Connecte-toi', desc: 'Une fois approuvé, clique sur le bouton ci-dessous ou cherche "Prime Roleplay" dans le navigateur FiveM.' },
];

const stats = [
  { n: 500, suffix: '+', label: 'Membres inscrits' },
  { n: 12,  suffix: '',  label: 'Factions actives' },
  { n: 200, suffix: '+', label: 'Véhicules custom' },
  { n: 3,   suffix: 'ans', label: 'D\'expérience' },
];
---
<Layout title="Prime Roleplay — Serveur FiveM GTA V">
  <Nav />
  <main>

    <!-- HERO -->
    <section class="hero">
      <div class="hero-bg"></div>
      <div class="hero-noise"></div>
      <div class="container">
        <div class="hero-badge">
          <span class="badge-dot"></span>
          Serveur en ligne • 51.222.255.96:30122
        </div>
        <h1 class="hero-title">
          <span class="line-1">PRIME</span>
          <span class="line-2">ROLEPLAY</span>
        </h1>
        <p class="hero-sub">
          Le serveur FiveM GTA V où chaque histoire compte.<br />
          Économie réaliste, factions profondes, communauté soudée.
        </p>
        <div class="hero-actions">
          <a class="btn-primary" href="fivem://connect/51.222.255.96:30122">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
            Jouer maintenant
          </a>
          <a class="btn-ghost" href="#join">Comment rejoindre</a>
        </div>
        <div class="hero-ip">
          <span>IP :</span>
          <code>51.222.255.96:30122</code>
        </div>
      </div>
      <div class="hero-scroll">
        <span></span>
        <p>Défiler</p>
      </div>
    </section>

    <!-- STATS -->
    <section class="stats-bar">
      <div class="container stats-grid">
        {stats.map((s, i) => (
          <div class={`stat-item reveal delay-${i + 1}`}>
            <div class="stat-n">
              <span data-count={s.n} data-suffix={s.suffix}>0{s.suffix}</span>
            </div>
            <p class="stat-label">{s.label}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- FEATURES -->
    <section class="features-section" id="features">
      <div class="container">
        <div class="section-header reveal">
          <p class="eyebrow">Expérience de jeu</p>
          <h2>Un univers <span>complet</span></h2>
          <p class="section-sub">Chaque aspect du roleplay a été pensé pour offrir l'immersion maximale.</p>
        </div>
        <div class="features-grid">
          {features.map((f, i) => (
            <div class={`feature-card reveal-scale delay-${(i % 3) + 1}`}>
              <div class="f-icon">{f.icon}</div>
              <h3>{f.title}</h3>
              <p>{f.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- HOW TO JOIN -->
    <section class="join-section" id="join">
      <div class="join-glow"></div>
      <div class="container">
        <div class="section-header reveal">
          <p class="eyebrow">Démarrer</p>
          <h2>Comment <span>rejoindre</span></h2>
          <p class="section-sub">Prêt à écrire ton histoire sur Prime RP ? 3 étapes simples.</p>
        </div>
        <div class="steps-grid">
          {steps.map((s, i) => (
            <div class={`step-card reveal delay-${i + 1}`}>
              <div class="step-num">{s.n}</div>
              <h3>{s.title}</h3>
              <p>{s.desc}</p>
            </div>
          ))}
        </div>
        <div class="join-cta reveal delay-3">
          <a class="btn-primary btn-lg" href="fivem://connect/51.222.255.96:30122">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
            Se connecter au serveur
          </a>
          <p class="join-ip"><code>51.222.255.96:30122</code></p>
        </div>
      </div>
    </section>

    <!-- STAFF -->
    <section class="staff-section" id="staff">
      <div class="container">
        <div class="section-header reveal">
          <p class="eyebrow">L'équipe</p>
          <h2>Notre <span>staff</span></h2>
          <p class="section-sub">Des passionnés dédiés à maintenir une expérience de jeu de qualité.</p>
        </div>
        <div class="staff-grid">
          <div class="staff-card reveal-scale">
            <div class="staff-avatar">
              <div class="avatar-ring"></div>
              <div class="avatar-inner">CM</div>
            </div>
            <div class="staff-info">
              <div class="staff-role">Fondateur</div>
              <h3>Calvin Mouse</h3>
              <p>Créateur et fondateur de Prime Roleplay. Passionné par le jeu de rôle de qualité depuis des années, Calvin a bâti ce serveur avec une vision claire : offrir l'expérience FiveM la plus immersive possible.</p>
              <div class="staff-badge">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                Propriétaire & Admin
              </div>
            </div>
          </div>
          <div class="staff-join reveal delay-2">
            <div class="sj-icon">🛡️</div>
            <h3>Rejoins l'équipe</h3>
            <p>Tu veux contribuer à Prime RP ? On recherche toujours des modérateurs, développeurs et responsables RP motivés. Postule sur notre Discord.</p>
            <a class="btn-ghost-sm" href="#community">Voir les postes ouverts</a>
          </div>
        </div>
      </div>
    </section>

    <!-- COMMUNITY / DISCORD CTA -->
    <section class="community-section" id="community">
      <div class="community-bg"></div>
      <div class="container community-inner reveal">
        <div class="comm-icon">💬</div>
        <h2>Rejoins la communauté</h2>
        <p>Plus de 500 membres actifs sur notre Discord. Règles du serveur, demandes de whitelist, événements et bien plus t'attendent.</p>
        <div class="comm-actions">
          <a class="btn-discord" href="https://discord.gg/primeroleplay" target="_blank" rel="noopener">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057c.002.024.015.046.036.062a19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/></svg>
            Rejoindre le Discord
          </a>
          <a class="btn-primary" href="fivem://connect/51.222.255.96:30122">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
            Jouer maintenant
          </a>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  main { padding-top: 68px; }
  .container { max-width: 1100px; margin: 0 auto; padding: 0 2rem; }
  .eyebrow { font-size: 0.72rem; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: var(--accent); margin-bottom: 0.75rem; }
  .section-header { text-align: center; margin-bottom: 4rem; }
  .section-header h2 { font-family: 'Rajdhani', sans-serif; font-size: clamp(2rem, 5vw, 3rem); font-weight: 700; letter-spacing: -0.02em; margin-bottom: 1rem; }
  .section-header h2 span { color: var(--accent); }
  .section-sub { font-size: 1rem; color: var(--gray); max-width: 520px; margin: 0 auto; line-height: 1.65; }

  /* Buttons */
  .btn-primary {
    display: inline-flex; align-items: center; gap: 0.5rem;
    background: var(--accent); color: #fff;
    padding: 0.85rem 1.75rem; border-radius: 8px;
    font-weight: 700; font-size: 0.9rem; letter-spacing: 0.03em;
    transition: background 0.2s, transform 0.2s;
  }
  .btn-primary:hover { background: var(--accent-dark); transform: translateY(-2px); }
  .btn-primary.btn-lg { padding: 1rem 2.25rem; font-size: 1rem; border-radius: 10px; }
  .btn-ghost {
    display: inline-flex; align-items: center;
    background: transparent; color: var(--gray);
    padding: 0.85rem 1.75rem; border-radius: 8px;
    font-weight: 600; font-size: 0.9rem; border: 1px solid var(--border);
    transition: color 0.2s, border-color 0.2s;
  }
  .btn-ghost:hover { color: var(--white); border-color: rgba(255,255,255,0.2); }
  .btn-ghost-sm {
    display: inline-flex; align-items: center;
    background: transparent; color: var(--gray);
    padding: 0.55rem 1.1rem; border-radius: 6px;
    font-weight: 600; font-size: 0.82rem; border: 1px solid var(--border);
    transition: color 0.2s, border-color 0.2s; margin-top: 0.5rem;
  }
  .btn-ghost-sm:hover { color: var(--white); border-color: rgba(255,255,255,0.2); }
  .btn-discord {
    display: inline-flex; align-items: center; gap: 0.5rem;
    background: #5865F2; color: #fff;
    padding: 0.85rem 1.75rem; border-radius: 8px;
    font-weight: 700; font-size: 0.9rem;
    transition: background 0.2s, transform 0.2s;
  }
  .btn-discord:hover { background: #4752c4; transform: translateY(-2px); }

  /* ── HERO ────────────────────────── */
  .hero {
    position: relative; min-height: 100vh;
    display: flex; align-items: center; justify-content: center;
    overflow: hidden; padding: 6rem 2rem 4rem;
  }
  .hero-bg {
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 70% 60% at 20% 50%, rgba(220,38,38,0.12) 0%, transparent 60%),
      radial-gradient(ellipse 50% 80% at 80% 20%, rgba(220,38,38,0.06) 0%, transparent 50%),
      var(--bg);
  }
  .hero-noise {
    position: absolute; inset: 0; opacity: 0.03;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='1'/%3E%3C/svg%3E");
    background-size: 200px 200px;
  }
  .hero > .container { position: relative; text-align: center; max-width: 820px; }
  .hero-badge {
    display: inline-flex; align-items: center; gap: 0.5rem;
    background: rgba(220,38,38,0.1); border: 1px solid rgba(220,38,38,0.25);
    border-radius: 999px; padding: 0.4rem 1rem;
    font-size: 0.78rem; font-weight: 600; color: rgba(248,248,248,0.7);
    margin-bottom: 2.5rem; letter-spacing: 0.04em;
    animation: heroEntrance 0.7s ease 0.1s both;
  }
  .badge-dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: #4ade80; flex-shrink: 0;
    box-shadow: 0 0 6px #4ade80;
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }
  .hero-title {
    font-family: 'Rajdhani', sans-serif;
    font-size: clamp(5rem, 15vw, 11rem);
    font-weight: 700; line-height: 0.9;
    letter-spacing: -0.03em;
    margin-bottom: 1.75rem;
  }
  .line-1 { display: block; color: var(--white); animation: heroEntrance 1s cubic-bezier(0.22,1,0.36,1) 0.25s both; }
  .line-2 { display: block; color: transparent; -webkit-text-stroke: 2px rgba(220,38,38,0.5); animation: heroEntrance 1s cubic-bezier(0.22,1,0.36,1) 0.42s both; }
  .hero-sub {
    font-size: 1.05rem; color: var(--gray); line-height: 1.7; max-width: 500px; margin: 0 auto 2.5rem;
    animation: heroEntrance 0.8s ease 0.65s both;
  }
  .hero-actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; animation: heroEntrance 0.7s ease 0.8s both; }
  .hero-ip {
    margin-top: 2rem; font-size: 0.82rem; color: rgba(255,255,255,0.3);
    animation: heroEntrance 0.7s ease 1s both;
  }
  .hero-ip code { color: rgba(255,255,255,0.5); background: rgba(255,255,255,0.05); padding: 0.2rem 0.5rem; border-radius: 4px; }
  .hero-scroll {
    position: absolute; bottom: 2.5rem; left: 50%; transform: translateX(-50%);
    display: flex; flex-direction: column; align-items: center; gap: 0.4rem;
    animation: heroEntrance 0.7s ease 1.3s both;
  }
  .hero-scroll span {
    display: block; width: 1px; height: 40px;
    background: linear-gradient(to bottom, transparent, var(--accent));
    animation: scrollLine 1.5s ease infinite;
  }
  .hero-scroll p { font-size: 0.68rem; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(255,255,255,0.2); }
  @keyframes scrollLine { 0%,100% { opacity: 0.3; transform: scaleY(0.5); } 50% { opacity: 1; transform: scaleY(1); } }
  @keyframes heroEntrance { from { opacity:0; transform: translateY(20px); } to { opacity:1; transform: none; } }

  /* ── STATS ───────────────────────── */
  .stats-bar { background: var(--bg-2); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); padding: 3rem 2rem; }
  .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 2rem; }
  .stat-item { text-align: center; }
  .stat-n { font-family: 'Rajdhani', sans-serif; font-size: 3rem; font-weight: 700; color: var(--accent); line-height: 1; margin-bottom: 0.4rem; }
  .stat-label { font-size: 0.8rem; color: var(--gray); font-weight: 500; letter-spacing: 0.04em; }

  /* ── FEATURES ────────────────────── */
  .features-section { padding: 7rem 2rem; background: var(--bg); }
  .features-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  .feature-card {
    background: var(--bg-3); border: 1px solid var(--border); border-radius: 16px;
    padding: 2rem; transition: border-color 0.3s, transform 0.3s;
  }
  .feature-card:hover { border-color: rgba(220,38,38,0.3); transform: translateY(-4px); }
  .f-icon { font-size: 2rem; margin-bottom: 1.25rem; }
  .feature-card h3 { font-size: 1rem; font-weight: 700; margin-bottom: 0.6rem; color: var(--white); }
  .feature-card p { font-size: 0.875rem; color: var(--gray); line-height: 1.65; }

  /* ── JOIN ────────────────────────── */
  .join-section { position: relative; padding: 7rem 2rem; background: var(--bg-2); overflow: hidden; }
  .join-glow { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 600px; height: 300px; background: radial-gradient(ellipse, rgba(220,38,38,0.06) 0%, transparent 70%); pointer-events: none; }
  .steps-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; margin-bottom: 4rem; }
  .step-card { background: var(--bg-3); border: 1px solid var(--border); border-radius: 16px; padding: 2rem; position: relative; overflow: hidden; }
  .step-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: linear-gradient(90deg, var(--accent), transparent); }
  .step-num { font-family: 'Rajdhani', sans-serif; font-size: 3.5rem; font-weight: 700; color: rgba(220,38,38,0.15); line-height: 1; margin-bottom: 1rem; }
  .step-card h3 { font-size: 1rem; font-weight: 700; margin-bottom: 0.6rem; }
  .step-card p { font-size: 0.875rem; color: var(--gray); line-height: 1.65; }
  .join-cta { text-align: center; }
  .join-ip { margin-top: 0.75rem; font-size: 0.82rem; color: rgba(255,255,255,0.3); }
  .join-ip code { color: rgba(255,255,255,0.45); }

  /* ── STAFF ───────────────────────── */
  .staff-section { padding: 7rem 2rem; background: var(--bg); }
  .staff-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; max-width: 820px; margin: 0 auto; }
  .staff-card {
    background: var(--bg-3); border: 1px solid var(--border); border-radius: 20px;
    padding: 2.5rem; display: flex; gap: 2rem; align-items: flex-start;
  }
  .staff-avatar { position: relative; flex-shrink: 0; width: 72px; height: 72px; }
  .avatar-ring { position: absolute; inset: -3px; border-radius: 50%; border: 2px solid var(--accent); animation: spin 8s linear infinite; }
  .avatar-ring::before { content: ''; position: absolute; top: -2px; left: 50%; width: 6px; height: 6px; background: var(--accent); border-radius: 50%; }
  @keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
  .avatar-inner { position: relative; width: 100%; height: 100%; border-radius: 50%; background: var(--accent-glow); border: 1px solid rgba(220,38,38,0.3); display: flex; align-items: center; justify-content: center; font-family: 'Rajdhani', sans-serif; font-size: 1.4rem; font-weight: 700; color: var(--accent); }
  .staff-role { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--accent); margin-bottom: 0.3rem; }
  .staff-info h3 { font-size: 1.2rem; font-weight: 800; margin-bottom: 0.75rem; }
  .staff-info p { font-size: 0.875rem; color: var(--gray); line-height: 1.65; margin-bottom: 0.75rem; }
  .staff-badge { display: inline-flex; align-items: center; gap: 0.35rem; background: rgba(220,38,38,0.08); border: 1px solid rgba(220,38,38,0.2); border-radius: 999px; padding: 0.25rem 0.7rem; font-size: 0.72rem; font-weight: 600; color: var(--accent); }
  .staff-join {
    background: var(--bg-3); border: 1px dashed rgba(255,255,255,0.1); border-radius: 20px;
    padding: 2.5rem; display: flex; flex-direction: column; align-items: flex-start; justify-content: center;
  }
  .sj-icon { font-size: 2rem; margin-bottom: 1rem; }
  .staff-join h3 { font-size: 1.1rem; font-weight: 700; margin-bottom: 0.6rem; }
  .staff-join p { font-size: 0.875rem; color: var(--gray); line-height: 1.65; }

  /* ── COMMUNITY ───────────────────── */
  .community-section { position: relative; padding: 8rem 2rem; overflow: hidden; }
  .community-bg { position: absolute; inset: 0; background: radial-gradient(ellipse 80% 100% at 50% 50%, rgba(220,38,38,0.08) 0%, transparent 60%), var(--bg-2); }
  .community-inner { position: relative; text-align: center; max-width: 620px; margin: 0 auto; }
  .comm-icon { font-size: 3rem; margin-bottom: 1.5rem; }
  .community-section h2 { font-family: 'Rajdhani', sans-serif; font-size: clamp(2rem, 5vw, 3rem); font-weight: 700; margin-bottom: 1rem; }
  .community-section p { font-size: 1rem; color: var(--gray); line-height: 1.7; margin-bottom: 2.5rem; }
  .comm-actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }

  /* ── RESPONSIVE ──────────────────── */
  @media (max-width: 900px) {
    .features-grid { grid-template-columns: 1fr 1fr; }
    .steps-grid { grid-template-columns: 1fr; }
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
    .staff-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 600px) {
    .features-grid { grid-template-columns: 1fr; }
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
    .staff-card { flex-direction: column; }
    .hero-actions { flex-direction: column; align-items: center; }
  }
</style>
